{
    # Global options
    email your-email@example.com
}

:80 {
    # Backend Admin (Match /admin or /admin/*)
    handle /admin* {
        reverse_proxy backend:8000
    }

    # Backend API
    handle /api* {
        reverse_proxy backend:8000
    }

    # Static files for Django Admin/API
    handle /static/* {
        root * /app/static
        file_server
    }

    # Media files
    handle /media/* {
        root * /app/media
        file_server
    }

    # Frontend Static Files (Fallback)
    handle {
        root * /usr/share/caddy
        file_server
        try_files {path} /index.html
    }

    # Optional: Gzip compression
    encode gzip
}
