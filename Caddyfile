{
    email {$CADDY_EMAIL:admin@example.com}
}

{$DOMAIN:localhost} {
    # Definimos lo que va al servidor Django
    @backend {
        path /api/* /admin* /static/* /media/*
    }

    # Logica para el Backend (API, Admin, Archivos estáticos)
    handle @backend {
        reverse_proxy backend:8000
    }

    # Logica para el Frontend (Todo lo demás)
    handle {
        root * /usr/share/caddy
        file_server
        try_files {path} /index.html
    }

    encode gzip
}
