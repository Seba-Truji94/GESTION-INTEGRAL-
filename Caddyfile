{
    # Global options
    email your-email@example.com
}

:80 {
    # Usamos route para forzar el orden de ejecución exacto
    route {
        # 1. Rutas del Backend (Prioridad alta)
        reverse_proxy /admin* backend:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
        reverse_proxy /api* backend:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }

        # 2. Archivos estáticos del Backend (CSS de Django Admin, etc)
        handle_path /static* {
            root * /app/static
            file_server
        }
        handle_path /media* {
            root * /app/media
            file_server
        }

        # 3. Frontend (Solo si lo anterior no coincide)
        handle {
            root * /usr/share/caddy
            file_server
            try_files {path} /index.html
        }
    }

    encode gzip
}
